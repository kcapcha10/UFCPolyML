# ── Polymarket ──────────────────────────────────────────────────────────────────
# Credentials for the CLOB API (https://docs.polymarket.com/)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# ── Kaggle ───────────────────────────────────────────────────────────────────────
# Needed only for the one-time cross-check; can also use ~/.kaggle/kaggle.json
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── MLflow ───────────────────────────────────────────────────────────────────────
# Leave blank to use the default local ./mlruns directory
MLFLOW_TRACKING_URI=

# ── DuckDB ───────────────────────────────────────────────────────────────────────
# Path to the DuckDB file; defaults to data/ufc_edge.duckdb
DUCKDB_PATH=

# ── Deployment ───────────────────────────────────────────────────────────────────
# Set to "true" to enable verbose logging in the capture cron
LOG_LEVEL=INFO
